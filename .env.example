DOMAIN=example.com
# Optional: email for Let's Encrypt notifications (used by Caddy global options)
ACME_EMAIL=

DB_NAME=dungeon
JWT_SECRET=change_me_to_a_long_random_secret

# For cookie auth:
# - In production with HTTPS: COOKIE_SECURE=true and COOKIE_SAMESITE=lax (recommended for same-site)
# - If you serve frontend+backend on the same domain (recommended), keep samesite=lax.
COOKIE_DOMAIN=example.com
COOKIE_SECURE=true
COOKIE_SAMESITE=lax

# Comma-separated list of allowed origins (exact). For same-domain deploy, you can set it to https://example.com
CORS_ORIGINS=https://example.com

